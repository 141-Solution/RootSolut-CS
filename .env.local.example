# SMTP-Konfiguration (optional – nur für E-Mail-Versand über Kontaktformular)
# Wenn nicht gesetzt, werden Anfragen nur in der Konsole protokolliert.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# CONTACT_TO=recipient@email.com
